# Copy this file to .env and fill in your credentials.
# .env is listed in .gitignore – never commit real credentials.

# Your school's numeric ID (shown in the school portal URL, e.g. ?i=1234)
SPH_SCHOOL_ID=1234

# Your portal username (without the school-id prefix)
SPH_USERNAME=max.mustermann

# Your portal password
SPH_PASSWORD=your_password_here
